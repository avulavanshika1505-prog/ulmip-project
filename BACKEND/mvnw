#!/bin/sh
# Licensed to the Apache Software Foundation (ASF)
set -e

# Resolve the real script location
PRG="$0"
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")/"$link"
  fi
done
PRGDIR=$(dirname "$PRG")
MAVEN_PROJECTBASEDIR=$(cd "$PRGDIR" > /dev/null && pwd)
export MAVEN_PROJECTBASEDIR

MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
DISTRIBUTION_URL=$(sed -n 's/^distributionUrl=//p' "$MAVEN_WRAPPER_PROPERTIES")
MAVEN_VERSION=$(echo "$DISTRIBUTION_URL" | sed -n 's/.*apache-maven-\([0-9.]*\)-.*/\1/p')
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-$MAVEN_VERSION"

if [ ! -d "$MAVEN_HOME" ]; then
  echo "Downloading Apache Maven $MAVEN_VERSION..."
  mkdir -p "$MAVEN_HOME"
  curl -fsSL "$DISTRIBUTION_URL" -o "/tmp/maven.zip"
  unzip -q "/tmp/maven.zip" -d "$MAVEN_HOME"
  rm "/tmp/maven.zip"
fi

MAVEN_BIN=$(find "$MAVEN_HOME" -name "mvn" -type f | head -1)
exec "$MAVEN_BIN" "$@"
